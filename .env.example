# Copy to .env and fill in ONE provider. If neither key is set, the service falls back to a
# deterministic rule-based planner (no LLM) that works from the structured request fields — so the
# app runs with zero secrets.

# Preferred: OpenRouter (OpenAI-compatible). Key: https://openrouter.ai/keys
OPENROUTER_API_KEY=
# OPENROUTER_MODEL=openai/gpt-5-mini

# Fallback: OpenAI direct
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-5-mini

# Allowed models for this key: gpt-4o-mini, gpt-4o-2024-08-06, gpt-4.1-nano, gpt-4.1-mini, gpt-4.1,
# gpt-5-mini, gpt-5, gpt-5.1, gpt-5.2, gpt-5.4-nano, gpt-5.4-mini, gpt-5.4.
# Planning is light structured extraction, so a *mini* is the sweet spot. Bump to gpt-5.4 for max
# quality, or gpt-4.1-mini for lower cost/latency.

# Planner temperature. Unset = the model's default (safest across models). Set to 0 for more
# deterministic planning on models that accept a non-default temperature.
# PLANNER_TEMPERATURE=0

# Refuse (rather than aggregate) result sets larger than this, so exact counts stay exact:
# TOO_BROAD_THRESHOLD=10000
