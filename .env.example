# Copy to .env and fill in ONE provider. If neither key is set, the service falls back to a
# deterministic rule-based planner (no LLM) that works from the structured request fields — so the
# app runs with zero secrets.

# Preferred: OpenRouter (OpenAI-compatible). Key: https://openrouter.ai/keys
OPENROUTER_API_KEY=
# OPENROUTER_MODEL=openai/gpt-4o-mini

# Fallback: OpenAI direct
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Refuse (rather than aggregate) result sets larger than this, so exact counts stay exact:
# TOO_BROAD_THRESHOLD=10000
